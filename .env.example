# Shadow Proxy Server Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PROXY_PORT=8080
PROXY_HOST=0.0.0.0

# SSL/TLS Configuration
SSL_ENABLED=false
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# Target Servers (comma-separated host:port)
PROXY_TARGETS=localhost:3000,localhost:3001

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# Redis Cache (optional)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_KEY_PREFIX=shadow:ratelimit:

# Load Balancer
LB_ALGORITHM=round-robin
LB_HEALTH_CHECK_INTERVAL=30000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout

# WebSocket
WS_ENABLED=true
WS_HEARTBEAT_INTERVAL=30000
